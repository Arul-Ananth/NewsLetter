APP_MODE=SERVER
SECRET_KEY=change_me

# Server networking
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Auth mode
AUTH_MODE=trusted_lan
TRUSTED_LAN_MODE=true
TRUSTED_LAN_USER_EMAIL=local@lan
TRUSTED_LAN_USER_NAME=Trusted LAN User
AUTH_SESSION_EXPIRE_MINUTES=720

# LLM config
LLM_PROVIDER=ollama
OPENAI_API_BASE=http://localhost:11434
OPENAI_MODEL_NAME=mistral:latest
OPENAI_API_KEY=
GEMINI_API_KEY=
SERPER_API_KEY=

# Logging/data
LOG_LEVEL=INFO
DATA_COLLECTION_ENABLED=true
CLIPBOARD_COLLECTION_ENABLED=false
CLIPBOARD_STORE_RAW_TEXT=false
